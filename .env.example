# PostgreSQL Connection
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nezha
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nezha
DB_USER=postgres
DB_PASSWORD=postgres

# AI Provider (for inner AI)
OPENAI_API_KEY=your-openai-key-here
OPENROUTER_API_KEY=your-openrouter-key-here

# Agent Configuration
AGENT_TYPE=psypi
SESSION_TIMEOUT=3600

# Logging
LOG_LEVEL=info
VERBOSE=false
